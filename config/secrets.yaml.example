# ============================================================
# SAnalysis - Secrets Configuration Template
#
# Copy this file to secrets.yaml and fill in your API keys:
#   cp secrets.yaml.example secrets.yaml
#
# IMPORTANT: secrets.yaml is git-ignored and should NEVER be committed.
# Alternatively, set environment variables (see below).
# ============================================================

api_keys:
  # Reddit API (required for Yellow Team sentiment_polarity scoring)
  # Get yours at: https://www.reddit.com/prefs/apps/
  # 1. Click "create another app..."
  # 2. Select "script" type
  # 3. Fill in name and redirect URI (http://localhost:8080)
  reddit_client_id: ""          # env: REDDIT_CLIENT_ID
  reddit_client_secret: ""      # env: REDDIT_CLIENT_SECRET
  reddit_user_agent: "SAnalysis/0.2 by MemeStockTeam"  # env: REDDIT_USER_AGENT

  # Future Phase 2+ keys:
  # finnhub_api_key: ""         # env: FINNHUB_API_KEY
  # alpha_vantage_key: ""       # env: ALPHA_VANTAGE_KEY
